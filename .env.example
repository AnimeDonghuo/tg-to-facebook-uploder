FILE: .env.example
```env
# --- Telegram ---
API_ID=
API_HASH=
BOT_TOKEN=
OWNER_ID=

# --- MongoDB ---
MONGODB_URL=
MONGODB_DATABASE=tg_facebook_uploader

# --- Security ---
# Generate with cryptography.fernet.Fernet.generate_key()
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# --- Meta API ---
GRAPH_API_VERSION=v19.0

# --- Server ---
PORT=8000

# --- Storage & Limits ---
TEMP_DIR=/tmp/tgfb
MIN_FREE_DISK_MB=512
MAX_TEMP_FILE_AGE_HOURS=24

# --- Queue & Worker ---
WORKER_CONCURRENCY=1
JOB_LEASE_SECONDS=600
JOB_HEARTBEAT_SECONDS=30

# --- Retries ---
MAX_RETRIES=5
RETRY_BASE_DELAY=60
RETRY_MAX_DELAY=3600

# --- UI & Performance ---
PROGRESS_UPDATE_SECONDS=7
TIMEZONE=UTC
LOG_LEVEL=INFO

# --- Retention ---
HISTORY_RETENTION_DAYS=30
LOG_RETENTION_DAYS=7
DRAFT_TTL_HOURS=24

# --- Permissions ---
ALLOW_ADMIN_PAGE_MANAGEMENT=false
