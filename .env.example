# Telegram
API_ID=
API_HASH=
BOT_TOKEN=
OWNER_ID=

# Database
MONGODB_URL=mongodb+srv://user:pass@cluster.mongodb.net/
MONGODB_DATABASE=tg_fb_uploader

# Security
# Generate via: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY=your_fernet_key_here

# Meta API
GRAPH_API_VERSION=v19.0

# Server
PORT=8000

# Storage
TEMP_DIR=/tmp/tgfb
MIN_FREE_DISK_MB=512

# Worker
WORKER_CONCURRENCY=1
JOB_LEASE_SECONDS=600

# Settings
PROGRESS_UPDATE_SECONDS=5
TIMEZONE=UTC
LOG_LEVEL=INFO
